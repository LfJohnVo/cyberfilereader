# ---- General ----
ENV=dev
LOG_LEVEL=INFO

# ---- API ----
API_HOST=0.0.0.0
API_PORT=5001
ALLOWED_ORIGINS=http://localhost:5173

# ---- Documentos ----
DOCS_DIR=./docs                 # en Docker: /data/docs
DATA_DIR=./data
ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.md,.xlsx,.csv
MAX_FILE_MB=25

# ---- RAG ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVER_K=5
SCORE_THRESHOLD=0.65            # coseno mínimo; calibrado nomic-embed-text (legítimas≥0.674, ruido≤0.698)

# ---- Ollama ----
OLLAMA_BASE_URL=http://localhost:11434   # en Docker: http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_NUM_CTX=8192
LLM_TEMPERATURE=0.1

# ---- Qdrant Cloud ----
QDRANT_URL=https://TU-CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=qdr-XXXXXXXXXXXXXXXX
QDRANT_COLLECTION=sgi_docs

# ---- Producción (perfil prod) ----
DATABASE_URL=postgresql+asyncpg://sgi:sgi@postgres:5432/sgi
REDIS_URL=redis://redis:6379/0
JWT_SECRET=cambia-esto-por-32-bytes-aleatorios
JWT_EXPIRE_MINUTES=480
POSTGRES_USER=sgi
POSTGRES_PASSWORD=sgi
POSTGRES_DB=sgi

# ---- Frontend ----
VITE_API_URL=http://localhost:5001
